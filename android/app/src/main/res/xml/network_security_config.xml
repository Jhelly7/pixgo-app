<?xml version="1.0" encoding="utf-8"?>
<!--
  Permite tráfego cleartext (HTTP) APENAS para localhost, onde corre o
  DecryptProxyServer (proxy que decripta os segmentos ChaCha20 e serve o
  HLS já decriptado ao video_player). Todo o resto do tráfego (API,
  streaming remoto) continua obrigatoriamente HTTPS.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
